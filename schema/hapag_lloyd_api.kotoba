// Hapag_lloyd_api clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace hapag_lloyd_api {

    entity TradeItem {
        id: string @unique
        gtin: string
        description: string
        brand: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Event {
        id: string @unique
        itemId: string
        bizStep: string
        disposition: string
        recordedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Document {
        id: string @unique
        type: string
        senderId: string
        receiverId: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Container {
        id: string @unique
        bicCode: string
        type: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Party {
        id: string @unique
        gln: string
        name: string
        role: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Shipment {
        id: string @unique
        documentId: string
        origin: string
        destination: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
